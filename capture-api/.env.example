# Railway injects DATABASE_URL when you attach a Postgres plugin. Tables auto-create on boot.
DATABASE_URL=postgresql://user:password@host:port/railway

# Password for the /dashboard report. CHANGE THIS.
ADMIN_KEY=change-me-to-something-long

# The customer demo URL used when building partner links (no trailing slash).
CUSTOMER_BASE_URL=https://services.getthedrix.com

# Railway sets PORT automatically.
PORT=3000
